# Backend Environment Variables
# Copy this file to .env and fill in your values

# Port for the Express server
PORT=5000

# Auth token from evaluation service (obtain from auth endpoint)
AUTH_TOKEN=your_bearer_token_here

# External evaluation service base URL
EXTERNAL_API_BASE_URL=http://20.207.122.201/evaluation-service

# Default number of top-N notifications returned by priority endpoint
DEFAULT_TOP_N=10
